# FastAPI settings
PROJECT_NAME="JinjjaAI Backend"

# Database connection
POSTGRES_SERVER="localhost"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres"
POSTGRES_DB="hangeulai"
POSTGRES_PORT=5432
# Alternatively, specify the full connection string directly
# DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/hangeulai"

# Redis
REDIS_HOST="localhost"
REDIS_PORT=6379

# Groq API Configuration
# Get your API key from https://console.groq.com/
GROQ_API_KEY="your_groq_api_key_here"

# JWT configuration
JWT_SECRET="SUPER_SECRET_KEY_FOR_LOCAL_DEV_CHANGE_IN_PRODUCTION"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
